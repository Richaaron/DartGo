# Environment Configuration for Vercel Deployment
# Copy these values to Vercel Dashboard → Settings → Environment Variables

# ==========================================
# CRITICAL: Backend API Configuration
# ==========================================

# For Vercel with backend on same Vercel project: use /api
# For external backend: use full URL (e.g., https://api.example.com or https://backend.example.com/api)
# Leave empty to auto-detect from current domain in production
VITE_API_URL=

# API Request Timeout (milliseconds)
VITE_API_TIMEOUT=30000

# ==========================================
# Application Settings
# ==========================================

VITE_APP_NAME=Folusho Result System
VITE_SCHOOL_NAME=Folusho Victory Schools
VITE_MAX_UPLOAD_SIZE=5242880

# ==========================================
# Feature Flags
# ==========================================

VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ADVANCED_ANALYTICS=true

# ==========================================
# Optional: Analytics & Monitoring
# ==========================================

# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ==========================================
# Backend Configuration (if deployed separately)
# ==========================================
# If your backend is running on a different server, set one of these:
# 1. Full backend URL: VITE_API_URL=https://api.yourdomain.com/api
# 2. Or just use the auto-detection by leaving VITE_API_URL empty
