# Environment Configuration Example
# Copy this file to .env.local and update values as needed

# API Configuration
# Primary: MongoDB (port 3002)
# Backup: Supabase (port 3001)
VITE_API_URL=http://localhost:3002/api
VITE_BACKUP_API_URL=http://localhost:3001/api
VITE_API_TIMEOUT=30000

# Application Settings
VITE_APP_NAME=Folusho Result System
VITE_SCHOOL_NAME=Folusho Victory Schools
VITE_MAX_UPLOAD_SIZE=5242880

# Feature Flags
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ADVANCED_ANALYTICS=true
